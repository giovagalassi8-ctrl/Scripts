library(ggplot2)

data <- read.csv("MS90_gappyout_allgenes_filtered.csv")

colnames(data)[1] <- "groups"

ggplot(data = data, aes(x = groups, y = Missing_percent), fill = groups) +
  geom_boxplot(
    outlier.shape = 21,
    outlier.size  = 2,
    alpha = 0.8
  ) +
  scale_fill_manual(
    values = c("Chaetonotida" = "blue", "Macrodasyida" = "darkgreen", "Platyhelmintes" = "red")
  ) +
  
  labs(
    x = "Taxonomic group",
    y = "Missing Percent (%)",
    fill = "groups"
  ) +
  
  theme_bw() +
  theme(
    plot.title   = element_text(face = "bold", size = 13, hjust = 0.5),
    axis.text.x  = element_text(size = 11),
    axis.title   = element_text(size = 12),
    legend.position = "none"
  )
